{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ build active file",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/debug/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "CMake: Build Test Target",
            "command": "/usr/bin/cmake --build build --target dbcpp_test",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Stabilna kompilacja przyrostowa pod WSL."
        }
    ],
    "version": "2.0.0"
}